# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password
# For local backend dev (outside Docker), Postgres is reachable at port 5433:
# DATABASE_URL=postgresql+asyncpg://argent:changeme_strong_password@localhost:5433/argent

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_strong_password
# For local backend dev (outside Docker), Redis is reachable at port 6380:
# REDIS_URL=redis://:changeme_strong_password@localhost:6380/0

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_TOKEN=changeme_chroma_token

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=changeme_strong_password

# ── LiveKit ────────────────────────────────────────────────────────────────────
# API key can be any string; secret must be ≥32 characters
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_must_be_at_least_32_chars_long

# ── Ollama / LLM ───────────────────────────────────────────────────────────────
OLLAMA_MODEL=qwen3:4b

# ── App / JWT ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_jwt_secret_at_least_32_chars_long

# ── Staff login (dashboard auth) ───────────────────────────────────────────────
STAFF_USERNAME=admin
STAFF_PASSWORD=changeme_strong_password

# ── Piper TTS ──────────────────────────────────────────────────────────────────
PIPER_MODEL=en_US-lessac-medium
